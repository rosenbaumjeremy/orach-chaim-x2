{
  // Cloudflare Pages project, deployed via `wrangler pages deploy ./site`
  // (set as this project's Deploy command in the dashboard). Nothing is
  // compiled: site/ is already the finished output. pages_build_output_dir
  // is required for wrangler to read this file at all for a Pages deploy -
  // without it, wrangler ignores the whole file, including "name" below.
  "name": "orach-chaim-x2",
  "compatibility_date": "2026-07-23",
  "pages_build_output_dir": "./site"
}
